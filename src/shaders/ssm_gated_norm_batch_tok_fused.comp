#version 460
// ZINC — Fused token-loop gated norm for SSM layers (prefill).
//
// Each workgroup processes ONE head across ALL n_tok tokens in a single
// dispatch, replacing the (dt_rank, n_tok, 1) grid of the per-token variant
// with (dt_rank, 1, 1). Eliminates the per-WG launch overhead that dominates
// the per-token variant (~2048 WGs → ~32 WGs for Qwen3.5-9B 64-token prefill).
//
// Grid: gl_WorkGroupID.x = head index (0..dt_rank-1)
// Token loop is internal via push-constant n_tok.

#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) readonly buffer DeltaNetOutput {
    float delta_net_output[];
};
layout(set = 0, binding = 1) readonly buffer ZGate {
    float z_gate[];
};
layout(set = 0, binding = 2) readonly buffer NormWeights {
    float norm_weight[];
};
layout(set = 0, binding = 3) writeonly buffer Output {
    float out_buf[];
};

layout(push_constant) uniform PushConstants {
    uint d_inner;
    uint dt_rank;
    uint head_v_dim;
    uint d_state;
    uint norm_per_head;
    uint n_tok;
};

shared float s_partial[64];

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint h = gl_WorkGroupID.x;
    uint head_base = h * head_v_dim;

    for (uint token = 0u; token < n_tok; token++) {
        uint data_base = token * d_inner + head_base;

        float sum_sq = 0.0;
        for (uint i = tid; i < head_v_dim; i += 64) {
            float val = delta_net_output[data_base + i];
            sum_sq += val * val;
        }

        sum_sq = subgroupAdd(sum_sq);

        if (gl_SubgroupSize < 64) {
            s_partial[tid] = sum_sq;
            barrier();
            if (tid == 0u) {
                float total = 0.0;
                uint num_subgroups = (64 + gl_SubgroupSize - 1u) / gl_SubgroupSize;
                for (uint s = 0u; s < num_subgroups; s++) {
                    total += s_partial[s * gl_SubgroupSize];
                }
                s_partial[0] = total;
            }
            barrier();
            sum_sq = s_partial[0];
        }

        float rms_inv = inversesqrt(sum_sq / float(head_v_dim) + 1e-6);

        for (uint i = tid; i < head_v_dim; i += 64) {
            float nv = delta_net_output[data_base + i] * rms_inv;
            uint norm_idx = (norm_per_head != 0u) ? (head_base + i) : (i % d_state);
            nv *= norm_weight[norm_idx];
            float zv = z_gate[data_base + i];
            float gate = zv / (1.0 + exp(-zv));
            out_buf[data_base + i] = nv * gate;
        }
    }
}
