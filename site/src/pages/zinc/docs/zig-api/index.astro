---
import DocLayout from '../../../../layouts/DocLayout.astro';
import DocsSearch from '../../../../components/DocsSearch.astro';
import { loadZigApi } from '../../../../lib/zig-api-loader';

const zigApi = await loadZigApi();

const supplementalDocs = [
  {
    href: '/zinc/docs/spec/',
    title: 'Technical Spec',
    description: 'Architecture notes, scheduling model, model support, and system design context behind the code reference.',
  },
  {
    href: '/zinc/docs/api/',
    title: 'HTTP API Reference',
    description: 'OpenAI-compatible request and response shapes for the serving interface built on top of the Zig runtime.',
  },
  {
    href: '/zinc/docs/rdna4-tuning/',
    title: 'RDNA4 Tuning',
    description: 'Architecture-specific performance findings and profiling notes that explain the GPU assumptions in the implementation.',
  },
  {
    href: '/zinc/docs/turboquant-spec/',
    title: 'TurboQuant',
    description: 'Background on the KV-cache compression approach that the runtime is designed to accommodate.',
  },
];

const agentArtifacts = [
  {
    href: '/zinc/docs/zig-api.json',
    title: 'JSON Export',
    description: 'Structured machine-readable dump of sections, modules, symbols, methods, doc tags, anchors, and source links.',
  },
  {
    href: '/zinc/docs/zig-api.txt',
    title: 'Plain Text Export',
    description: 'Single text artifact of the Zig API for retrieval-oriented agents and lightweight ingestion.',
  },
  {
    href: '/llms.txt',
    title: 'LLMs Index',
    description: 'Root agent entrypoint that tells clients to use the Zig API first and points to supplemental docs second.',
  },
];

const description = 'Generated reference for the ZINC Zig codebase, grouped by runtime responsibility with module pages and stable symbol anchors.';
const keywords = 'ZINC Zig API, generated docs, Zig reference, Vulkan runtime, inference runtime, GGUF parser, AMD GPU';
const zigCodeLines = zigApi.codeLineCount.toLocaleString('en-US');
const githubSrcUrl = 'https://github.com/zolotukhin/zinc/tree/main/src';
const apiSearchSuggestions = ['InferenceEngine', 'DmmvDispatch', 'GGUFFile', 'Tokenizer', 'ServerState', 'ModelConfig'];
const entryModuleSlugs = ['forward', 'forward-metal', 'graph', 'gguf', 'tokenizer', 'dmmv', 'elementwise', 'routes'];
const entryModules = entryModuleSlugs
  .map(slug => zigApi.modules.find(module => module.slug === slug))
  .filter(module => module !== undefined);
---

<DocLayout title="Zig API" description={description} keywords={keywords} lastmod={zigApi.lastmod}>
  <div class="api-page">
  <div class="api-main">
  <section class="hero">
    <p class="eyebrow">Primary Reference</p>
    <h1>ZINC Zig API</h1>
    <p class="hero-copy">
      This is the main documentation surface for the codebase: generated from <code>src/**/*.zig</code>, grouped by
      functionality, and linked with stable module and symbol anchors.
    </p>

    <div class="hero-actions">
      <a href="#sections" class="button button-primary">Browse API Sections</a>
      {zigApi.modules[0] && <a href={zigApi.modules[0].href} class="button button-secondary">Open First Module</a>}
      <a href={githubSrcUrl} class="button button-metric" target="_blank" rel="noreferrer">
        <span class="button-metric-top">
          <svg class="button-metric-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"></path>
          </svg>
          <span class="button-metric-label">Zig Lines</span>
        </span>
        <strong>{zigCodeLines}</strong>
      </a>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <span>Sections</span>
        <strong>{zigApi.sections.length}</strong>
      </div>
      <div class="stat-card">
        <span>Modules</span>
        <strong>{zigApi.moduleCount}</strong>
      </div>
      <div class="stat-card">
        <span>Exports</span>
        <strong>{zigApi.exportCount}</strong>
      </div>
      <div class="stat-card">
        <span>Methods</span>
        <strong>{zigApi.memberCount}</strong>
      </div>
    </div>
  </section>

  <section id="api-search" class="api-search-panel">
    <div class="section-header">
      <div>
        <p class="eyebrow">Find Code</p>
        <h2>Search modules, symbols, and methods</h2>
      </div>
    </div>
    <DocsSearch
      compact={true}
      placeholder="Search the Zig API by symbol, method, module, or source path"
      scope="zig-api"
      suggestions={apiSearchSuggestions}
      maxResults={12}
    />
  </section>

  <div id="sections" class="section-stack">
    {zigApi.sections.map(section => (
      <section class="section-card" id={section.slug}>
        <div class="section-header">
          <div>
            <p class="eyebrow">API Section</p>
            <h2>{section.title}</h2>
          </div>
          <span class="section-count">{section.symbolCount} symbols</span>
        </div>
        <p class="section-description">{section.description}</p>

        <div class="module-grid">
          {section.modules.map(module => (
            <a href={module.href} class="module-card">
              <div class="module-card-top">
                <span class="module-source">{module.sourcePath}</span>
                <span class="module-counts">{module.exportCount} exports · {module.memberCount} methods</span>
              </div>
              <h3>{module.title}</h3>
              <p>{module.summary}</p>
              <ul class="symbol-preview">
                {module.symbols.slice(0, 4).map(symbol => (
                  <li>{symbol.name}</li>
                ))}
              </ul>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  {entryModules.length > 0 && (
    <section id="entry-points" class="entry-points">
      <div class="section-header">
        <div>
          <p class="eyebrow">Developer Entry Points</p>
          <h2>Start with the hot paths</h2>
        </div>
      </div>
      <div class="entry-grid">
        {entryModules.map(module => (
          <a href={module.href} class="entry-link">
            <span class="entry-source">{module.sourcePath}</span>
            <strong>{module.title}</strong>
            <span>{module.summary}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section id="machine-readable" class="supplemental">
    <div class="section-header">
      <div>
        <p class="eyebrow">Agent Access</p>
        <h2>Machine-Readable Entry Points</h2>
      </div>
    </div>
    <p class="section-description">
      Agents should prefer the generated Zig API exports instead of scraping HTML. The JSON export is the canonical
      structured surface; <code>llms.txt</code> points callers at the right docs in the right order.
    </p>

    <div class="module-grid supplemental-grid">
      {agentArtifacts.map(artifact => (
        <a href={artifact.href} class="module-card supplemental-card">
          <h3>{artifact.title}</h3>
          <p>{artifact.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="supplemental">
    <div class="section-header">
      <div>
        <p class="eyebrow">Supplemental</p>
        <h2>Architecture and Narrative Docs</h2>
      </div>
    </div>
    <p class="section-description">
      These pages support the API reference with higher-level specs, tuning notes, and protocol descriptions. They are
      intentionally secondary to the generated Zig reference.
    </p>

    <div class="module-grid supplemental-grid">
      {supplementalDocs.map(doc => (
        <a href={doc.href} class="module-card supplemental-card">
          <h3>{doc.title}</h3>
          <p>{doc.description}</p>
        </a>
      ))}
    </div>
  </section>
  </div><!-- .api-main -->

  <aside class="api-nav">
    <p class="nav-title">On This Page</p>
    <ul>
      <li><a href="#api-search">Search</a></li>
      <li><a href="#sections">API Sections</a></li>
      {entryModules.length > 0 && <li><a href="#entry-points">Entry Points</a></li>}
      <li><a href="#machine-readable">Machine-Readable</a></li>
      {zigApi.sections.map(section => (
        <li class="nav-section">
          <a href={`#${section.slug}`}>{section.title}</a>
          <ul>
            {section.modules.map(mod => (
              <li><a href={mod.href}>{mod.title}</a></li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </aside>
  </div><!-- .api-page -->
</DocLayout>

<style>
  .api-page {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 190px;
    gap: var(--space-md);
    align-items: start;
  }

  .api-main {
    min-width: 0;
  }

  .api-nav {
    position: sticky;
    top: 1rem;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    padding: 0.25rem 0;
  }

  .nav-title {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.35rem;
  }

  .api-nav > ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .api-nav li {
    margin: 0;
  }

  .api-nav > ul > li {
    margin-bottom: 0.08rem;
  }

  .api-nav a {
    display: block;
    font-size: 0.68rem;
    line-height: 1.25;
    padding: 0.1rem 0;
    color: var(--color-text-muted);
  }

  .api-nav a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-section > a {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.7rem;
    margin-top: 0.32rem;
  }

  .nav-section > ul {
    list-style: none;
    padding-left: 0.6rem;
    margin: 0;
    border-left: 1px solid var(--color-border);
  }

  .nav-section > ul a {
    font-size: 0.64rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 960px) {
    .api-page {
      grid-template-columns: 1fr;
    }

    .api-nav {
      display: none;
    }
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 0.42fr);
    grid-template-areas:
      "eyebrow stats"
      "title stats"
      "copy stats"
      "actions stats";
    column-gap: var(--space-md);
    align-items: start;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    margin-bottom: var(--space-md);
  }

  .hero h1 {
    grid-area: title;
    margin: 0 0 0.25rem;
    font-size: 1.75rem;
  }

  .hero-copy {
    grid-area: copy;
    color: var(--color-text-muted);
    max-width: 62ch;
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .eyebrow {
    grid-area: eyebrow;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .hero-actions {
    grid-area: actions;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin: 0.45rem 0 0;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0 0.65rem;
    border-radius: 8px;
    font-size: 0.78rem;
    border: 1px solid var(--color-border);
    text-decoration: none;
  }

  .button-primary {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .button-secondary {
    color: var(--color-text);
    background: var(--color-bg);
  }

  .button-metric {
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.1rem;
    min-height: 2rem;
    padding: 0.34rem 0.65rem;
    background: color-mix(in srgb, var(--color-accent) 7%, var(--color-bg));
    border-color: color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-text);
  }

  .button-metric-top {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }

  .button-metric-icon {
    width: 0.85rem;
    height: 0.85rem;
    flex: none;
    fill: currentColor;
    color: var(--color-accent);
  }

  .button-metric-label {
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .button-metric strong {
    font-size: 0.9rem;
    line-height: 1.1;
    font-weight: 700;
  }

  .button-metric:hover {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 11%, var(--color-bg));
  }

  .button:hover {
    text-decoration: none;
  }

  .stats-grid {
    grid-area: stats;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .stat-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    padding: 0.45rem 0.55rem;
  }

  .stat-card span {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    margin-bottom: 0.08rem;
  }

  .stat-card strong {
    font-size: 1.1rem;
  }

  .section-stack {
    display: grid;
    gap: var(--space-md);
  }

  .api-search-panel,
  .entry-points,
  .section-card,
  .supplemental {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md);
    background: var(--color-bg);
  }

  .api-search-panel {
    margin-bottom: var(--space-md);
  }

  .entry-points {
    margin-bottom: var(--space-md);
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.45rem;
    margin-top: 0.65rem;
  }

  .entry-link {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
    padding: 0.45rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .entry-link:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .entry-link strong {
    font-size: 0.78rem;
    line-height: 1.25;
  }

  .entry-link span:last-child {
    color: var(--color-text-muted);
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    font-size: 0.68rem;
    line-height: 1.3;
  }

  .entry-source {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.56rem;
    overflow-wrap: anywhere;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    align-items: flex-start;
    margin-bottom: 0.45rem;
  }

  .section-header h2 {
    margin: 0;
  }

  .section-count {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .section-description {
    color: var(--color-text-muted);
    max-width: 70ch;
    margin-bottom: 0;
    font-size: 0.82rem;
    line-height: 1.4;
  }

  .module-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
    margin-top: 0.75rem;
  }

  .module-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.65rem 0.75rem;
    color: var(--color-text);
    background: var(--color-bg);
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .module-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-accent) 4%, var(--color-bg));
  }

  .module-card-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-bottom: 0.25rem;
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .module-source,
  .module-counts {
    display: inline-flex;
  }

  .module-card h3 {
    margin: 0 0 0.12rem;
    font-size: 0.95rem;
  }

  .module-card p {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    line-height: 1.35;
    margin-bottom: 0.45rem;
  }

  .symbol-preview {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.22rem;
  }

  .symbol-preview li {
    margin: 0;
    padding: 0.08rem 0.32rem;
    border-radius: 5px;
    background: var(--color-bg-alt);
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .section-card .module-card {
    display: grid;
    grid-template-columns: minmax(145px, 0.8fr) minmax(210px, 1.35fr) minmax(145px, 0.85fr);
    grid-template-areas:
      "meta title symbols"
      "meta summary symbols";
    column-gap: var(--space-md);
    row-gap: 0.12rem;
    align-items: start;
  }

  .section-card .module-card-top {
    grid-area: meta;
    display: grid;
    justify-content: stretch;
    gap: 0.18rem;
    margin: 0;
  }

  .section-card .module-source {
    font-family: var(--font-mono);
    overflow-wrap: anywhere;
  }

  .section-card .module-counts {
    font-variant-numeric: tabular-nums;
  }

  .section-card .module-card h3 {
    grid-area: title;
  }

  .section-card .module-card p {
    grid-area: summary;
    margin: 0;
  }

  .section-card .symbol-preview {
    grid-area: symbols;
    justify-content: flex-start;
  }

  .supplemental {
    margin-top: var(--space-md);
  }

  #machine-readable {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .supplemental-grid {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    margin-top: 0.65rem;
  }

  .supplemental-card h3 {
    margin-bottom: var(--space-xs);
  }

  @media (max-width: 700px) {
    .hero,
    .api-search-panel,
    .entry-points,
    .section-card,
    .supplemental {
      padding: var(--space-md);
    }

    .hero {
      display: block;
      padding: 0.85rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-header,
    .module-card-top {
      display: block;
    }

    .section-count,
    .module-counts {
      display: inline-block;
      margin-top: var(--space-xs);
    }

    .section-card .module-card {
      display: block;
    }
  }
</style>
